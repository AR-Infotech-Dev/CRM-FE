{
  "name": "crm-ui-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "react": "vite",
    "react_build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron_dev": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run react\" \"npm run electron_dev\"",
    "dist": "npm run react_build && electron-builder"
  },
  "build": {
    "appId": "com.ar_infotech.flowups",
    "productName": "FlowupS CallDesk",
    "directories": {
      "output": "release 0.0.1"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.2",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "dnd-kit": "^0.0.2",
    "dotenv": "^17.4.1",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.453.0",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.14.0",
    "react-toastify": "^11.0.5",
    "react-window": "^1.8.10",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.8",
    "wait-on": "^9.0.5"
  }
}
